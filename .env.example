# Supabase (source)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# Snowflake (destination)
SNOWFLAKE_ACCOUNT=<org>-<account>
SNOWFLAKE_USER=<user>
SNOWFLAKE_PASSWORD=<password>
SNOWFLAKE_ROLE=ONEONONE_LOADER          # role the session runs as (least privilege)
SNOWFLAKE_WAREHOUSE=ONEONONE_WH
SNOWFLAKE_DATABASE=ONEONONE_DB
SNOWFLAKE_SCHEMA=RAW

# MetricFlow — workaround for dbt-metricflow 0.13.0 + dbt-core 1.11 version mismatch.
# mf CLI can't find profiles without this. Prefix ALL mf commands with this var,
# or export it in your shell session: export DBT_PROFILES_DIR=~/.dbt
# DBT_PROFILES_DIR=~/.dbt
